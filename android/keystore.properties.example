# Vorlage für die Release-Signierung.
# Kopiere diese Datei nach android/keystore.properties und trage deine Werte ein.
# Die echte keystore.properties ist in .gitignore und darf NICHT committet werden.

storeFile=../regelexperte-release.keystore
storePassword=DEIN_KEYSTORE_PASSWORT
keyAlias=regelexperte
keyPassword=DEIN_KEY_PASSWORT
